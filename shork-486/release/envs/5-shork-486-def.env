INCLUDE_SC_IM=true
INCLUDE_SHORKSTALL=false
INCLUDE_SHORKTAINMENT=true
INCLUDE_STRACE=true
INCLUDE_TCC=true
INCLUDE_TILDE=false
INCLUDE_TN5250=false
INCLUDE_TNFTP=true
INCLUDE_TMUX=true
INCLUDE_UTIL_LINUX=true
ENABLE_CDROM=true
INCLUDE_CON_FONTS=true
USE_GRUB=false
ENABLE_FB=true
INCLUDE_GUI=false
ENABLE_HIGHMEM=false
