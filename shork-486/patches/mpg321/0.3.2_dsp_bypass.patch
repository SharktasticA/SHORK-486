diff --git a/ao.c b/ao.c
index 4d9fc42..9c54204 100644
--- a/ao.c
+++ b/ao.c
@@ -35,6 +35,9 @@
 #include <stdio.h>
 #include <string.h>
 #include <signal.h>
+#include <sys/soundcard.h>
+
+int oss_fd = -1;
 
 void set_play_device(char *devicename)
 {
@@ -502,25 +505,21 @@ void open_ao_playdevice(struct mad_header const *header)
             } else opened++;
         }
 
-        if(!opened &&  options.opt & MPG321_USE_OSS)
+        if(!opened && options.opt & MPG321_USE_OSS)
         {
-            ao_option *ao_options = NULL;
-            int driver_id = ao_driver_id("oss");
-
-            if(options.device)
-                ao_append_option(&ao_options, "dsp", options.device);
-
-            if((playdevice=ao_open_live(driver_id, &format, ao_options))==NULL)
-            {
-                if (options.device)
-                {
-                    fprintf(stderr, "Can't open libao driver with device %s (is device in use?)\n",
-                        options.device);
-                    exit(1);
-                }
-                else
-                options.opt |= MPG321_USE_SUN;
-            } else opened++;
+            const char *dsp = options.device ? options.device : "/dev/dsp";
+            int fmt = AFMT_S16_LE;
+            int ch = MAD_NCHANNELS(header);
+            int sp = header->samplerate;
+            
+            oss_fd = open(dsp, O_WRONLY);
+            if (oss_fd >= 0) {
+                ioctl(oss_fd, SNDCTL_DSP_SETFMT, &fmt);
+                ioctl(oss_fd, SNDCTL_DSP_CHANNELS, &ch);
+                ioctl(oss_fd, SNDCTL_DSP_SPEED, &sp);
+                playdevice = (ao_device *)&oss_fd;
+                opened++;
+            }
         }
 
         if(!opened && options.opt & MPG321_USE_SUN)
diff --git a/mad.c b/mad.c
