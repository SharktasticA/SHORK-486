diff --git a/libbb/utmp.c b/libbb/utmp.c
index bd07670db..6d7a916ef 100644
--- a/libbb/utmp.c
+++ b/libbb/utmp.c
@@ -14,6 +14,31 @@ static void touch(const char *filename)
 		close(open(filename, O_WRONLY | O_CREAT, 0664));
 }
 
+static void write_utmpx(const char *path, struct utmpx *utent, pid_t pid)
+{
+	struct utmpx tmp;
+	int found = 0;
+
+	int fd = open(path, O_RDWR | O_CREAT, 0664);
+	if (fd < 0) return;
+
+	while (read(fd, &tmp, sizeof(tmp)) == sizeof(tmp)) {
+		if (tmp.ut_pid == pid) {
+			lseek(fd, -(off_t)sizeof(tmp), SEEK_CUR);
+			write(fd, utent, sizeof(*utent));
+			found = 1;
+			break;
+		}
+	}
+
+	if (!found) {
+		lseek(fd, 0, SEEK_END);
+		write(fd, utent, sizeof(*utent));
+	}
+
+	close(fd);
+}
+
